# ============================================
# CebStore E-Commerce API Configuration
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env file to version control
# ============================================

# ============================================
# SERVER CONFIGURATION
# ============================================
NODE_ENV=development
PORT=3001
API_PREFIX=api/v1

# ============================================
# DATABASE CONFIGURATION
# ============================================
# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database?schema=public
DATABASE_URL="postgresql://mohamed:hashassi@localhost:5432/e-commerce-cebstore"

# Slow query logging threshold (milliseconds)
SLOW_QUERY_THRESHOLD_MS=1000

# ============================================
# SECURITY - JWT CONFIGURATION
# ============================================
# IMPORTANT: Use strong, random secrets in production (min 32 characters)
# Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters
JWT_EXPIRATION=15m

REFRESH_SECRET=your-super-secret-refresh-key-minimum-32-characters
REFRESH_EXPIRATION=7d

# Bcrypt hashing rounds (higher = more secure but slower)
BCRYPT_ROUNDS=12

# ============================================
# CORS CONFIGURATION
# ============================================
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ============================================
# RATE LIMITING
# ============================================
# Number of requests allowed per TTL window
THROTTLE_LIMIT=10
# Time window in seconds
THROTTLE_TTL=60

# ============================================
# OPENAI API CONFIGURATION
# ============================================
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_CHAT_MODEL=gpt-3.5-turbo
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=1000

# ============================================
# REDIS CACHE CONFIGURATION
# ============================================
# Full Redis URL (overrides HOST/PORT if set)
REDIS_URL=redis://localhost:6379

# Alternative: separate host/port configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Cache TTL settings (in seconds)
CACHE_DEFAULT_TTL=3600
CACHE_PRODUCTS_TTL=1800
CACHE_CATEGORIES_TTL=7200
CACHE_USERS_TTL=900
CACHE_ORDERS_TTL=300
CACHE_MAX_ITEMS=10000

# ============================================
# PAYMENT - FLOUCI CONFIGURATION
# ============================================
FLOUCI_APP_PUBLIC=your-flouci-public-key
FLOUCI_APP_SECRET=your-flouci-secret-key
FLOUCI_SANDBOX=true

# Payment redirect URLs
FLOUCI_SUCCESS_URL=http://localhost:3000/payments/success
FLOUCI_FAIL_URL=http://localhost:3000/payments/fail
FLOUCI_WEBHOOK_URL=http://localhost:3001/api/v1/payments/webhook
FLOUCI_WEBHOOK_SECRET=your-webhook-secret

# ============================================
# WORKFLOW AUTOMATION - N8N
# ============================================
N8N_BASE_URL=http://localhost:5678
N8N_ORDER_WEBHOOK=http://localhost:5678/webhook/order-created
N8N_PAYMENT_WEBHOOK=http://localhost:5678/webhook/payment-completed

# ============================================
# FILE UPLOAD CONFIGURATION
# ============================================
UPLOAD_DIR=./uploads/images
MAX_FILE_SIZE=5242880

# CDN configuration (optional)
CDN_URL=https://cdn.cebstore.com

# Image optimization
IMAGE_QUALITY=80
IMAGE_FORMAT=webp

# ============================================
# HTTPS CONFIGURATION (Production)
# ============================================
HTTPS_ENABLED=false
SSL_KEY_PATH=./ssl/private.key
SSL_CERT_PATH=./ssl/certificate.crt

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=debug
