# ==================== APPLICATION ====================
NODE_ENV=development
PORT=3001
API_PREFIX=api/v1

# ==================== BASE DE DONNÉES ====================
DATABASE_URL="postgresql://user:password@localhost:5432/cebstore?schema=public"

# ==================== SÉCURITÉ ====================
# JWT
JWT_SECRET=votre_secret_jwt_tres_long_et_secu rise_ici_minimum_32_caracteres
JWT_EXPIRATION=15m
REFRESH_SECRET=votre_refresh_secret_jwt_ici_minimum_32_caracteres
REFRESH_EXPIRATION=7d

# Bcrypt
BCRYPT_ROUNDS=12

# HTTPS (Production uniquement)
HTTPS_ENABLED=false
SSL_KEY_PATH=./ssl/private.key
SSL_CERT_PATH=./ssl/certificate.crt

# ==================== CORS ====================
ALLOWED_ORIGINS=http://localhost:3000,https://cebstore.com

# ==================== RATE LIMITING ====================
THROTTLE_TTL=60
THROTTLE_LIMIT=10

# ==================== OPENAI ====================
OPENAI_API_KEY=sk-votre_cle_api_openai
OPENAI_EMBEDDING_MODEL=text-embedding-ada-002
OPENAI_CHAT_MODEL=gpt-3.5-turbo
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=1000

# ==================== PAIEMENT (FLOUCI) ====================
FLOUCI_API_KEY=votre_cle_api_flouci
FLOUCI_SECRET=votre_secret_flouci
FLOUCI_WEBHOOK_SECRET=votre_secret_webhook
FLOUCI_MODE=test

# ==================== WORKFLOWS (N8N) ====================
N8N_BASE_URL=http://localhost:5678
N8N_WEBHOOK_SECRET=votre_secret_webhook_n8n

# ==================== EMAIL (Optionnel) ====================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre_email@gmail.com
SMTP_PASS=votre_mot_de_passe_application

# ==================== REDIS (Cache) ====================
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Cache
CACHE_DEFAULT_TTL=3600          # 1 heure
CACHE_MAX_ITEMS=10000           # Nombre max d'éléments en cache

# Cache par type
CACHE_PRODUCTS_TTL=1800         # 30 minutes
CACHE_CATEGORIES_TTL=7200       # 2 heures
CACHE_USERS_TTL=900             # 15 minutes
CACHE_ORDERS_TTL=300            # 5 minutes

# ==================== IMAGES & CDN ====================
UPLOAD_DIR=./uploads/images
MAX_FILE_SIZE=5242880           # 5MB en octets

# CDN (Cloudflare, Cloudfront, etc.)
CDN_URL=https://cdn.cebstore.com

# Optimisation images
IMAGE_QUALITY=80
IMAGE_FORMAT=webp

# ==================== LOGS ====================
LOG_LEVEL=debug
